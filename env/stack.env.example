PROJECT_NAME=tender-stack
STACK_NETWORK=tender-stack_default

# Domains (optional, for your reverse proxy / Caddy config)
API_DOMAIN=api.example.com
FRONTEND_DOMAIN=app.example.com

# Host port for parser-api
API_PORT=8787

# Frontend container (optional profile "frontend")
FRONTEND_ENABLED=1
FRONTEND_PORT=8088
FRONTEND_VITE_API_BASE=/api
