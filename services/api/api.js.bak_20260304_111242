    try {
      if (!AUTH_JWT_SECRET) {
        return sendJson(res, 500, { error: 'AUTH_JWT_SECRET is not configured.' });
      }
      const body = await readJsonBody(req);
      const email = typeof body.email === 'string' ? body.email.trim() : '';
      const password = typeof body.password === 'string' ? body.password : '';
      if (!email || !password) {
        return sendJson(res, 400, { error: 'Email and password are required.' });
      }

      if (email === AUTH_ADMIN_USERNAME) {
        if (!AUTH_ADMIN_PASSWORD) {
          return sendJson(res, 500, { error: 'AUTH_ADMIN_PASSWORD is not configured.' });
        }
        if (password !== AUTH_ADMIN_PASSWORD) {
          return sendJson(res, 401, { error: 'Invalid credentials.' });
        }
        const token = signJwt(
          { sub: 'admin', email: AUTH_ADMIN_USERNAME, role: 'admin' },
          AUTH_JWT_SECRET,
          AUTH_JWT_TTL
        );
        return sendJson(res, 200, {
          access_token: token,
          token_type: 'bearer',
          expires_in: AUTH_JWT_TTL,
        });
      }

      const user = await findUserByEmail(email);
      if (!user || !user.password_hash || !user.is_active) {
        return sendJson(res, 401, { error: 'Invalid credentials.' });
      }
      const passwordValid = verifyPassword(password, user.password_hash);
      if (!passwordValid) {
        return sendJson(res, 401, { error: 'Invalid credentials.' });
      }

      const token = signJwt(
        {
          sub: String(user.id),
          email: user.email,
          role: user.role || 'viewer',
        },
        AUTH_JWT_SECRET,
        AUTH_JWT_TTL
      );

      try {
        await updateUserLastLogin(user.id);
      } catch (error) {
        console.warn('Failed to update last_login_at:', error);
      }

      const result = {
        access_token: token,
        token_type: 'bearer',
        expires_in: AUTH_JWT_TTL,
      };
      return sendJson(res, 200, result);
    } catch (error) {
      const message =
        error instanceof Error ? error.message : 'Failed to sign in.';
