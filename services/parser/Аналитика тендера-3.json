{
  "name": "Аналитика тендера",
  "nodes": [
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH doc_summary AS (\n  -- Собираем контекст из документов\n  SELECT \n    object_number,\n    jsonb_agg(jsonb_build_object(\n      'doc_kind', doc_kind_code,\n      'summary', summary,\n      'risks', risk_flags,\n      'terms', key_terms\n    )) as docs_context\n  FROM tender_attachments_summary\n  GROUP BY object_number\n),\nitems_summary AS (\n  SELECT \n    object_number,\n    COUNT(*) as items_count,\n    jsonb_agg(jsonb_build_object(\n      'name', item_name,\n      'price', price_for_one,\n      'qty', quantity_value,\n      'foreign_ban', is_prohibition_foreign,\n      'okpd2', okpdname,\n      'characteristics_len', CASE \n                               WHEN jsonb_typeof(characteristics_detailed_json) = 'array' \n                               THEN jsonb_array_length(characteristics_detailed_json) \n                               ELSE 0 \n                             END\n    )) FILTER (WHERE id IS NOT NULL) as items_sample\n  FROM tender_items\n  GROUP BY object_number\n)\nSELECT \n  tg.object_number,\n  tg.maxprice,\n  tg.startdt,\n  tg.enddt,\n  tg.placingway_name,\n  tg.fullname as customer_fullname,\n  tg.inn as customer_inn,\n  tg.deliveryplace,\n  tg.is_subcontractors_req,\n  tg.is_small_or_middle,\n  \n  COALESCE(ds.docs_context, '[]'::jsonb) as docs,\n  COALESCE(isum.items_sample, '[]'::jsonb) as items\n  \nFROM tenders_gov tg\nJOIN doc_summary ds ON tg.object_number = ds.object_number\nLEFT JOIN items_summary isum ON tg.object_number = isum.object_number\nLEFT JOIN tender_analytics ta ON tg.object_number = ta.object_number\nWHERE ta.id IS NULL \n  -- Доп фильтр: берем только если есть хоть какие-то доки или товары, чтобы не тратить токены на пустышки\n  AND (ds.docs_context IS NOT NULL OR isum.items_sample IS NOT NULL)\nLIMIT 5;\n",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -112,
        0
      ],
      "id": "3a9fd7f2-3b05-4dd0-bfab-5ba0e1ae5073",
