function isLikelyLegalQuestion(message) {
  const q = String(message || '').toLowerCase();
  if (!q.trim()) return false;
  if (q.includes('44') || q.includes('223') || q.includes('фз')) return true;
  return /(закон|стат(ь|и)я|част(ь|и)|пункт|пп\.|соответств|нарушен|жалоб|фас|обжал)/i.test(
    q
  );
}

