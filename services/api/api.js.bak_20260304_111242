function formatVector(values, expectedDim) {
  if (!Array.isArray(values) || values.length !== expectedDim) {
    throw new Error(`Embedding dimension mismatch: got ${values?.length}, expected ${expectedDim}`);
  }
  return `[${values.map((v) => (Number.isFinite(v) ? Number(v).toFixed(8) : '0')).join(',')}]`;
}

async function embedQuery(text) {
  const { apiKey, baseUrl, model, dim } = getEmbeddingsConfig();
  const res = await fetch(`${baseUrl}/embeddings`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      Authorization: `Bearer ${apiKey}`,
    },
    body: JSON.stringify({ model, input: text, dimensions: dim }),
  });
  const t = await res.text();
  let json = null;
  try {
    json = t ? JSON.parse(t) : null;
  } catch {
    json = null;
  }
  if (!res.ok) {
    throw new Error(`Embeddings HTTP ${res.status} ${res.statusText}: ${t}`);
  }
  if (json?.error) {
    throw new Error(`Embeddings provider error: ${JSON.stringify(json.error)}`);
  }
  const emb = json?.data?.[0]?.embedding;
  return formatVector(emb, dim);
}

async function loadTenderBasics(objectNumber) {
  const params = new URLSearchParams();
