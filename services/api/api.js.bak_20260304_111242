function extractCitationIds(text) {
  const out = new Set();
  // Allow formats like "[T3]" and "[T3, раздел 1]" (model sometimes adds extra details).
  const re = /\[((?:[TL]\d+))(?:[^\]]*)\]/g;
  let match;
  while ((match = re.exec(String(text || '')))) {
    out.add(match[1]);
  }
  return Array.from(out);
}

function simplifyRagQueryText(text) {
  const raw = String(text || '').toLowerCase();
  const cleaned = raw.replace(/[^0-9a-zа-яё]+/giu, ' ');
  const tokens = cleaned.split(/\s+/).filter(Boolean);
  if (tokens.length === 0) return '';

  // Extra conversational tokens that Postgres FTS does not always discard.
  const drop = new Set([
    'нужно',
    'нужен',
    'нужна',
    'нужны',
    'надо',
    'требуется',
    'что',
    'какой',
    'какая',
    'какие',
    'какое',
    'когда',
    'где',
    'почему',
    'как',
    'есть',
    'ли',
    'какие-то',
    'какой-то',
    'какая-то',
    'какое-то',
    'это',
    'этот',
    'эта',
    'эти',
  ]);

  const kept = [];
  for (const token of tokens) {
    if (token.length <= 2) continue;
    if (drop.has(token)) continue;
    kept.push(token);
  }

  return kept.join(' ').trim();
}

function sanitizeRagContentForDisplay(text) {
  let out = String(text || '');

  // Drop inline base64 images often produced by PDF extraction; they destroy layout and are useless for quoting.
  out = out.replace(/!\[Image\]\(data:image\/[^)]*\)/gi, '[image]');
  out = out.replace(/data:image\/[a-z0-9.+-]+;base64,[a-z0-9+/=]{200,}/gi, '[image]');
  out = out.replace(/\[image\]/gi, ' ');
  out = out.replace(/^#{1,6}\s+/gm, '');

  // Collapse excessive whitespace/newlines.
  out = out.replace(/\r\n/g, '\n');
  out = out.replace(/[ \t]+\n/g, '\n');
  out = out.replace(/\n{3,}/g, '\n\n');
  out = out.replace(/[ \t]{2,}/g, ' ');

  return out.trim();
}

function splitIntoCandidateSentences(text) {
  const normalized = String(text || '')
    .replace(/\r\n/g, '\n')
    .replace(/\u00a0/g, ' ')
    .replace(/\n{2,}/g, '\n')
    .trim();
  if (!normalized) return [];

  const byPunctuation =
    normalized
      .split(/\n|(?<=[.!?…;])\s+/g)
      .map((part) => String(part || '').trim())
      .filter(Boolean) || [];
  const out = [];
  for (const chunk of byPunctuation) {
    const cleaned = chunk
      .replace(/^[\-*•\s]+/, '')
      .replace(/^\d+(?:[.)]|\.\d+)*\s*/, '')
      .replace(/\s+/g, ' ')
      .trim();
    if (!cleaned) continue;
    out.push(cleaned);
  }
  return out;
}

function normalizeCitationSentence(sentence, maxLen = 420) {
  let out = String(sentence || '').replace(/\s+/g, ' ').trim();
  if (!out) return '';

  // Remove obvious leading punctuation/noise.
  out = out.replace(/^[,;:)\]}\-–—\s]+/, '');
  out = out.replace(/^N\s*\d+[^)]*\)\s*/i, '');
  out = out.replace(/^№?\s*\d+\s*[-‑–]?\s*фз\)?\s*/i, '');
  out = out.replace(/^[а-яё]\)\s*/i, '');
  out = out.replace(/^\d+(?:\.\d+)*\s+/, '');
  out = out.replace(/^["'`]+/, '');
  out = out.replace(/\s+["'`]+$/, '');

  if (out.length > maxLen) {
    const soft = out.slice(0, maxLen);
    const punct = Math.max(soft.lastIndexOf('.'), soft.lastIndexOf(';'), soft.lastIndexOf('!'), soft.lastIndexOf('?'));
    if (punct > Math.floor(maxLen * 0.6)) {
      out = soft.slice(0, punct + 1).trim();
    } else {
      out = `${soft.trim()}…`;
    }
  }
  return out;
}

function isCleanCitationSentence(sentence) {
  const s = String(sentence || '').trim();
  if (!s) return false;
  if (s.length < 30) return false;
  // Avoid obviously chopped sentence starts.
  if (/^[а-яё]/.test(s)) return false;
  if (!/^[А-ЯЁA-Z0-9«"(]/.test(s)) return false;
  if (/[|]{2,}/.test(s)) return false;
  if (/data:image\//i.test(s)) return false;
  const letters = (s.match(/[A-Za-zА-Яа-яЁё]/g) || []).length;
  const digits = (s.match(/\d/g) || []).length;
  if (letters < 20) return false;
  if (digits > letters) return false;
  return true;
}

function buildCitationExcerpt(content, queryText, maxLen = 260) {
  const text = sanitizeRagContentForDisplay(content);
  if (!text) return '';

  const simplified = simplifyRagQueryText(queryText);
  const terms = (simplified || String(queryText || ''))
    .toLowerCase()
    .replace(/[^0-9a-zа-яё]+/giu, ' ')
    .split(/\s+/)
    .filter((t) => t && t.length > 2)
    .slice(0, 12);

  const sentences = splitIntoCandidateSentences(text);
  if (sentences.length > 0) {
    let bestSentence = '';
    let bestScore = -Infinity;
    let bestCleanSentence = '';
    let bestCleanScore = -Infinity;

      for (const sentence of sentences) {
        const lower = sentence.toLowerCase();
        let hits = 0;
        for (const term of terms) {
          if (lower.includes(term)) hits += 1;
        }
        const startsLikeSentence = /^[А-ЯЁA-Z0-9«"(\[]/.test(sentence);
        const hasEndingPunct = /[.!?…]$/.test(sentence);
        const docNumberingCount = (sentence.match(/\b\d+\.\d+\b/g) || []).length;
        const digitCount = (sentence.match(/\d/g) || []).length;
        const letterCount = (sentence.match(/[A-Za-zА-Яа-яЁё]/g) || []).length || 1;
        const numericNoisePenalty = digitCount > letterCount * 0.45 ? -5 : 0;
        const lengthPenalty = sentence.length > 420 ? -1 : 0;
        const score =
          hits * 10 +
          (startsLikeSentence ? 2 : -2) +
          (hasEndingPunct ? 1 : 0) +
          numericNoisePenalty +
          docNumberingCount * -2 +
          lengthPenalty;

      if (score > bestScore) {
        bestScore = score;
        bestSentence = sentence;
      }
      if (isCleanCitationSentence(sentence) && score > bestCleanScore) {
        bestCleanScore = score;
        bestCleanSentence = sentence;
      }
    }

    if (bestCleanSentence) {
      return normalizeCitationSentence(bestCleanSentence, Math.max(260, maxLen));
    }
    if (bestSentence) {
      const normalized = normalizeCitationSentence(bestSentence, Math.max(260, maxLen));
      return isCleanCitationSentence(normalized) ? normalized : '';
    }
  }

  // Fallback for edge cases where sentence split fails.
  const compact = text.replace(/\s+/g, ' ').trim();
  if (compact.length <= maxLen && /[.!?…]$/.test(compact) && isCleanCitationSentence(compact)) return compact;
  return '';
}

async function generateRagSearchQueries(userMessage, tender) {
  const { apiKey, baseUrl, model } = getAiConfig();
  if (!apiKey) return [];

  const tenderHint = tender
    ? [
        tender.zakon ? `Закон: ${tender.zakon}` : null,
        tender.placingway_name ? `Способ: ${tender.placingway_name}` : null,
        tender.fullname ? `Заказчик: ${tender.fullname}` : null,
        tender.deliveryplace ? `Место: ${tender.deliveryplace}` : null,
      ]
        .filter(Boolean)
        .join('\n')
    : '';

  const system = [
    'Ты — помощник, который подбирает поисковые запросы для полнотекстового поиска по документам тендера.',
    'Верни только валидный JSON без пояснений.',
    'Формат: {"queries":["..."],"clarify":false,"question":""}',
    'queries: 3-6 коротких фраз (2-6 слов), без стоп-слов (что/нужно/как/ли), по сути вопроса, на русском.',
    'Если вопрос слишком общий или неясный: clarify=true и question — один уточняющий вопрос.',
  ].join('\n');

  const prompt = [
    tenderHint ? `Контекст тендера:\n${tenderHint}` : null,
    `Вопрос пользователя:\n${String(userMessage || '').trim()}`,
  ]
    .filter(Boolean)
    .join('\n\n');

  const res = await fetch(`${baseUrl}/chat/completions`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      Authorization: `Bearer ${apiKey}`,
    },
    body: JSON.stringify({
      model,
      temperature: 0.1,
      max_tokens: 220,
      messages: [
        { role: 'system', content: system },
        { role: 'user', content: prompt },
      ],
    }),
  });

  const raw = await res.text();
  if (!res.ok) return [];
  let json = null;
  try {
    json = raw ? JSON.parse(raw) : null;
  } catch {
    return [];
  }
  const queries = Array.isArray(json?.queries) ? json.queries : [];
  return queries
    .map((q) => (typeof q === 'string' ? q.trim() : ''))
    .filter(Boolean)
    .slice(0, 6);
}

async function retrieveTenderMatches(objectNumber, queryText) {
  const mode = String(process.env.RAG_SEARCH_MODE || 'auto').toLowerCase();
  if (mode === 'fts') {
    const simplified = simplifyRagQueryText(queryText);
    const primaryQuery = simplified || String(queryText || '');
    let rows = await callSupabaseRpc('match_rag_tender_chunks_fts', {
      match_object_number: objectNumber,
      query_text: primaryQuery,
      match_count: 10,
    });
    if (
      Array.isArray(rows) &&
      rows.length === 0 &&
      simplified &&
      simplified !== String(queryText || '')
    ) {
      return callSupabaseRpc('match_rag_tender_chunks_fts', {
        match_object_number: objectNumber,
        query_text: String(queryText || ''),
        match_count: 10,
      });
    }
    if (!Array.isArray(rows)) rows = [];

    // If recall is still low, ask the LLM to derive better keyword queries and merge results.
    if (rows.length < 3) {
      const tender = await loadTenderBasics(objectNumber);
      const extraQueries = await generateRagSearchQueries(queryText, tender);
      if (extraQueries.length > 0) {
        const merged = new Map();
        for (const r of rows) merged.set(String(r.id), r);
        for (const q of extraQueries) {
          try {
            const more = await callSupabaseRpc('match_rag_tender_chunks_fts', {
              match_object_number: objectNumber,
              query_text: q,
              match_count: 10,
            });
            if (Array.isArray(more)) {
              for (const r of more) merged.set(String(r.id), r);
            }
          } catch {
            // ignore
          }
        }
        rows = Array.from(merged.values());
      }
    }

    return rows;
  }

  try {
    const queryVector = await embedQuery(queryText);
    const rows = await callSupabaseRpc('match_rag_tender_chunks', {
      match_object_number: objectNumber,
      query_embedding: queryVector,
      match_count: 10,
    });
    if (Array.isArray(rows) && rows.length > 0) {
      return rows;
    }
  } catch (err) {
    // fall back
  }

  return callSupabaseRpc('match_rag_tender_chunks_fts', {
    match_object_number: objectNumber,
    query_text: queryText,
    match_count: 10,
  });
}

async function retrieveLegalMatches(corpus, queryText) {
  const mode = String(process.env.RAG_SEARCH_MODE || 'auto').toLowerCase();
  if (mode === 'fts') {
    const simplified = simplifyRagQueryText(queryText);
    const primaryQuery = simplified || String(queryText || '');
    let rows = await callSupabaseRpc('match_rag_legal_chunks_fts', {
      match_corpus: corpus,
      query_text: primaryQuery,
      match_count: 6,
    });
    if (
      Array.isArray(rows) &&
      rows.length === 0 &&
      simplified &&
      simplified !== String(queryText || '')
    ) {
      return callSupabaseRpc('match_rag_legal_chunks_fts', {
        match_corpus: corpus,
        query_text: String(queryText || ''),
        match_count: 6,
      });
    }
    if (!Array.isArray(rows)) rows = [];

    if (rows.length < 3) {
      const extraQueries = await generateRagSearchQueries(queryText, null);
      if (extraQueries.length > 0) {
        const merged = new Map();
        for (const r of rows) merged.set(String(r.id), r);
        for (const q of extraQueries) {
          try {
            const more = await callSupabaseRpc('match_rag_legal_chunks_fts', {
              match_corpus: corpus,
              query_text: q,
              match_count: 6,
            });
            if (Array.isArray(more)) {
              for (const r of more) merged.set(String(r.id), r);
            }
          } catch {
            // ignore
          }
        }
        rows = Array.from(merged.values());
      }
    }

    return rows;
  }

  try {
    const queryVector = await embedQuery(queryText);
    const rows = await callSupabaseRpc('match_rag_legal_chunks', {
      match_corpus: corpus,
      query_embedding: queryVector,
      match_count: 6,
    });
    if (Array.isArray(rows) && rows.length > 0) {
      return rows;
    }
  } catch (err) {
    // fall back
  }

  return callSupabaseRpc('match_rag_legal_chunks_fts', {
    match_corpus: corpus,
    query_text: queryText,
    match_count: 6,
  });
}

async function generateAssistantReply({ objectNumber, userMessage, history }) {
  const tender = await loadTenderBasics(objectNumber);
  const tenderMatches = await retrieveTenderMatches(objectNumber, userMessage);

  const tenderSources = (Array.isArray(tenderMatches) ? tenderMatches : []).map((row, idx) => ({
    id: `T${idx + 1}`,
    attachment_id: row.attachment_id,
    source_path: row.source_path,
    source_name: row.source_name,
    content: row.content,
    similarity: row.similarity,
  }));

  const useLegal = isLikelyLegalQuestion(userMessage);
  let legalSources = [];
  if (useLegal) {
    const corpuses = ['44fz', '223fz'];
    for (const corpus of corpuses) {
      try {
        const legalMatches = await retrieveLegalMatches(corpus, userMessage);
        const rows = Array.isArray(legalMatches) ? legalMatches : [];
        for (const row of rows) {
          legalSources.push({
            corpus,
            section: row.section,
            source_url: row.source_url,
            as_of_date: row.as_of_date,
            content: row.content,
            similarity: row.similarity,
          });
        }
      } catch {
        // If legal corpus isn't seeded yet, the assistant will answer without it.
      }
    }
    legalSources = legalSources
      .sort((a, b) => (b.similarity || 0) - (a.similarity || 0))
      .slice(0, 8)
      .map((row, idx) => ({ ...row, id: `L${idx + 1}` }));
  }

  if (useLegal && legalSources.length === 0) {
    let legalCount = 0;
    try {
      const params = new URLSearchParams();
      params.set('corpus', 'in.(44fz,223fz)');
      legalCount = await countSupabase('rag_legal_chunks', params);
    } catch {
      // If Supabase isn't reachable, fall back to safe message below.
    }

    if (legalCount === 0) {
      return {
        answer:
          'Юридический корпус (44‑ФЗ/223‑ФЗ) ещё не загружен, поэтому я не могу дать правовую оценку без риска выдумывания. Загрузите закон в RAG‑корпус и повторите вопрос.',
        citations: [],
      };
    }

    return {
      answer:
        'Юридический корпус загружен, но по текущей формулировке я не нашёл релевантных фрагментов закона, чтобы ответить с обязательными цитатами. Уточните, что именно проверить (например: обеспечение заявки/контракта, требования к участнику, сроки/этапы, критерии оценки, состав заявки), и я отвечу с ссылками на нормы.',
      citations: [],
    };
  }

  const tenderCtx = tenderSources
    .map((s) => {
      const title = s.source_path || s.source_name || `attachment:${s.attachment_id}`;
      return `[Источник ${s.id}] Документ: ${title}\n${s.content}`;
    })
    .join('\n\n');

  const legalCtx = legalSources
    .map((s) => {
      const title = `${s.corpus.toUpperCase()}${s.section ? `, ${s.section}` : ''}${s.as_of_date ? ` (ред. ${s.as_of_date})` : ''}`;
      return `[Источник ${s.id}] Закон: ${title}${s.source_url ? `\nURL: ${s.source_url}` : ''}\n${s.content}`;
    })
    .join('\n\n');

  const tenderMeta = tender
    ? [
        `Номер: ${tender.object_number}`,
        tender.zakon ? `Закон: ${tender.zakon}` : null,
        tender.placingway_name ? `Способ: ${tender.placingway_name}` : null,
        tender.fullname ? `Заказчик: ${tender.fullname}` : null,
        tender.inn ? `ИНН заказчика: ${tender.inn}` : null,
        tender.maxprice ? `НМЦК: ${tender.maxprice}` : null,
        tender.startdt ? `Начало: ${tender.startdt}` : null,
        tender.enddt ? `Окончание: ${tender.enddt}` : null,
        tender.deliveryplace ? `Место поставки: ${tender.deliveryplace}` : null,
      ]
        .filter(Boolean)
        .join('\n')
    : '';

  const system = [
    'Ты — ИИ-помощник по конкретному тендеру.',
    '',
    'Правила:',
    '1) Отвечай строго по фактам из источников ниже. Если факта нет в источниках, прямо скажи, что в документах это не найдено.',
    '2) После каждого важного утверждения ставь ссылку на источник в квадратных скобках: [T1], [T2] для документов тендера, [L1] для закона.',
    '3) Если вопрос про соответствие 44-ФЗ/223-ФЗ или правовую оценку: используй только источники L* и обязательно цитируй.',
    '4) Не выдумывай статьи/пункты. Если не уверен или нет контекста, предложи что именно нужно уточнить.',
    '5) Если вопрос общий или двусмысленный: сначала задай 1 уточняющий вопрос (не больше одного), затем предложи, какие данные из документов ты можешь проверить.',
    '6) Если ответ получается длинным списком: дай до 8 пунктов, а дальше напиши, что можешь продолжить по запросу.',
    '7) Пиши обычным текстом. Не используй Markdown (звёздочки **, заголовки ##). Для списков используй дефис "-".',
    '8) Отвечай кратко и структурно.',
  ].join('\n');

  const historyText = (Array.isArray(history) ? history : [])
    .filter((m) => m && (m.role === 'user' || m.role === 'assistant'))
    .slice(-10)
    .map((m) => `${m.role === 'user' ? 'Пользователь' : 'Ассистент'}: ${m.content}`)
    .join('\n');

  const prompt = [
    tenderMeta ? `Данные тендера:\n${tenderMeta}` : null,
    historyText ? `Контекст диалога:\n${historyText}` : null,
    tenderCtx ? `Источники по тендеру:\n${tenderCtx}` : 'Источники по тендеру: (пусто)',
    useLegal
      ? (legalCtx ? `Источники по законам:\n${legalCtx}` : 'Источники по законам: (не загружены)')
      : null,
    `Вопрос пользователя:\n${userMessage}`,
  ]
    .filter(Boolean)
    .join('\n\n');

  const { apiKey, baseUrl, model } = getAiConfig();
  const res = await fetch(`${baseUrl}/chat/completions`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      Authorization: `Bearer ${apiKey}`,
    },
    body: JSON.stringify({
      model,
      messages: [
        { role: 'system', content: system },
        { role: 'user', content: prompt },
      ],
    }),
  });

  if (!res.ok) {
    const t = await res.text();
    throw new Error(`LLM HTTP ${res.status} ${res.statusText}: ${t}`);
  }

  const json = await res.json();
  const answer = json?.choices?.[0]?.message?.content?.trim() || '';

  const usedIds = extractCitationIds(answer);
  const citations = [];
  for (const id of usedIds) {
    if (id.startsWith('T')) {
      const src = tenderSources[Number(id.slice(1)) - 1];
      if (src) {
        citations.push({
          id,
          type: 'tender',
          title: src.source_path || src.source_name || `attachment:${src.attachment_id}`,
          attachment_id: src.attachment_id,
          snippet: buildCitationExcerpt(src.content || '', userMessage, 260),
        });
      }
    } else if (id.startsWith('L')) {
      const src = legalSources[Number(id.slice(1)) - 1];
      if (src) {
        citations.push({
          id,
          type: 'law',
          title: `${src.corpus.toUpperCase()}${src.section ? `, ${src.section}` : ''}`,
          source_url: src.source_url || null,
          as_of_date: src.as_of_date || null,
          snippet: buildCitationExcerpt(src.content || '', userMessage, 260),
        });
      }
    }
  }

  return { answer: answer || 'Не удалось сформировать ответ.', citations };
}

