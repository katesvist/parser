# Database
DATABASE_URL=postgres://user:pass@host:5432/dbname
# Optional split form (if DATABASE_URL is not used):
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=
PGPOOL_MAX=10

# Schedules
INGEST_CRON=*/5 * * * *
DOCS_CRON=*/20 * * * *
ANALYTICS_CRON=*/20 * * * *
ARCHIVE_CRON=17 3 * * *

# Ingest / RSS tuning
INGEST_LIMIT=50
INGEST_LOOKBACK_DAYS=30
INGEST_PAGES=1
INGEST_RECORDS_PER_PAGE=_200
INGEST_INSERT_BATCH=200
ZAKUPKI_THROTTLE_MS=2000

# Reconcile tuning
RECONCILE_LIMIT=200
RECONCILE_HOT_LIMIT=1000
RECONCILE_LOOKBACK_DAYS=180
RECONCILE_RECORDS_PER_PAGE=_200
RECONCILE_ZAKUPKI_THROTTLE_MS=1000
RECONCILE_HTTP_TIMEOUT_MS=60000
RECONCILE_HTTP_RETRIES=3
RECONCILE_HTTP_RETRY_DELAY_MS=2000
FULL_SWEEP_MAX_LOOPS=500
FULL_SWEEP_DELAY_MS=500

# Archive tuning
ARCHIVE_AFTER_DAYS=30
ARCHIVE_LIMIT=200
ARCHIVE_CLEANUP_ENABLED=true
ARCHIVE_DELETE_MAIN_ENABLED=false
ARCHIVE_TERMINAL_IMMEDIATE=true

# Keywords file
KEYWORDS_FILE=/app/config/keywords.json

# Docs worker
DOCS_LIMIT=50
DOCS_DELAY_MS=2000
DOCS_TEXT_LIMIT=50000
DOCS_DOWNLOAD_TIMEOUT_MS=120000
DOCS_DOWNLOAD_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0 Safari/537.36
DOCS_DOWNLOAD_REFERER=https://zakupki.gov.ru/
DOCS_MIN_TEXT_LENGTH=50

# Doc parsing / conversion
DOCLING_URL=http://docling:5001
DOCLING_API_VERSION=auto
DOCLING_FORCE_OCR=false
DOCLING_OCR_IF_NO_TEXT=true
DOCLING_OCR_LANG=ru,en
DOCLING_RESULT_RETRIES=5
DOCLING_RESULT_DELAY_MS=2000
DOCLING_USE_ASYNC=true
DOCS_XLS_CONVERT=true
DOCS_XLS_TIMEOUT_MS=120000
DOCS_DOC_CONVERT=true
DOCS_DOC_TIMEOUT_MS=120000
DOCS_ARCHIVE_ENABLED=true
DOCS_ARCHIVE_MAX_FILES=25
DOCS_ARCHIVE_MAX_FILE_SIZE_MB=25
DOCS_ARCHIVE_EXTRACT_TIMEOUT_MS=120000

# LLM / embeddings (OpenRouter/OpenAI-compatible)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
LLM_MODEL=google/gemini-2.5-flash

EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIM=1536

# RAG
RAG_TENDER_INDEX_ENABLED=true
RAG_SEARCH_MODE=hybrid
RAG_TEXT_LIMIT=120000
RAG_CHUNK_MAX_CHARS=1400
RAG_CHUNK_OVERLAP_CHARS=200
RAG_MIN_CHUNK_CHARS=300
RAG_MAX_CHUNKS_PER_DOC=200
RAG_EMBED_BATCH_SIZE=32

# Legal RAG seed (optional)
LEGAL_44FZ_SOURCE_URL=
LEGAL_223FZ_SOURCE_URL=
LEGAL_AS_OF_DATE=
RAG_LEGAL_TEXT_LIMIT=2500000
RAG_LEGAL_CHUNK_MAX_CHARS=1600
RAG_LEGAL_CHUNK_OVERLAP_CHARS=250
RAG_LEGAL_MIN_CHUNK_CHARS=400
RAG_LEGAL_MAX_CHUNKS=3000
