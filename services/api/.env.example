# API server
API_PORT=8787

# Supabase REST
# Can be full /rest/v1 URL or just domain; server appends /rest/v1 automatically.
SUPABASE_REST_URL=https://supabase-api.example.com
SUPABASE_SERVICE_ROLE_KEY=change-me

# Auth
AUTH_JWT_SECRET=change-me
AUTH_JWT_TTL=3600
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=change-me

# Access / CORS
API_KEYS=
CORS_ORIGINS=https://app.example.com

# Pagination/search defaults
API_DEFAULT_LIMIT=200
API_MAX_LIMIT=500
SEARCH_MORPHOLOGY_ENABLED=true
SEARCH_MORPHOLOGY_CONFIG=russian

# LLM / Embeddings
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash
CHAT_LLM_MODEL=google/gemini-2.5-flash
EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIM=1536
RAG_SEARCH_MODE=hybrid

# Optional table overrides
FAVORITES_TABLE=favorite_tenders
SAVED_SEARCHES_TABLE=saved_searches
KANBAN_TABLE=tender_kanban
ASSIGNMENTS_TABLE=tender_assignments
ASSISTANT_THREADS_TABLE=assistant_threads
ASSISTANT_MESSAGES_TABLE=assistant_messages
RAG_TENDER_STATUS_TABLE=rag_tender_index_status
