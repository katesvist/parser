async function getAnalyticsStatus(objectNumber) {
  const attachmentsParams = new URLSearchParams();
  attachmentsParams.set('object_number', `eq.${objectNumber}`);
  // Exclude archives and docx.pdf in counts to match worker-docs eligibility
  attachmentsParams.append(
    'or',
    `(file_name.is.null,and(file_name.not.ilike.*.zip,file_name.not.ilike.*.rar,file_name.not.ilike.*.7z,file_name.not.ilike.*.docx.pdf))`,
  );
  attachmentsParams.append(
    'or',
    `(url.is.null,and(url.not.ilike.*.zip*,url.not.ilike.*.rar*,url.not.ilike.*.7z*))`,
  );

  const summaryParams = new URLSearchParams();
  summaryParams.set('object_number', `eq.${objectNumber}`);

  const [total, summarized, requestedAt, job] = await Promise.all([
    countSupabase('tender_attachments', attachmentsParams),
    countSupabase('tender_attachments_summary', summaryParams),
    getAnalyticsRequestedAt(objectNumber),
    getAnalyticsJob(objectNumber),
  ]);

  const done = total > 0 && summarized >= total;
  return {
    object_number: objectNumber,
    requested_at: requestedAt,
    total_attachments: total,
    summarized_attachments: summarized,
    pending_attachments: Math.max(0, total - summarized),
    done,
    job,
  };
}

function readJsonBody(req) {
  return new Promise((resolve, reject) => {
    let body = '';
    req.on('data', (chunk) => {
      body += chunk;
      if (body.length > 1_000_000) {
        reject(new Error('Payload too large.'));
        req.destroy();
      }
    });
    req.on('end', () => {
      if (!body) {
        return resolve({});
      }
      try {
        resolve(JSON.parse(body));
      } catch (error) {
        reject(new Error('Invalid JSON body.'));
      }
    });
    req.on('error', reject);
  });
}

async function getRagTenderAssistantStatus(objectNumber) {
  const params = new URLSearchParams();
  params.set('select', 'object_number,status,chunk_count,error,updated_at');
  params.set('object_number', `eq.${objectNumber}`);
  params.set('limit', '1');

  let row = null;
  try {
    const response = await fetchSupabase(RAG_TENDER_STATUS_TABLE, params);
    const rows = Array.isArray(response.data) ? response.data : [];
    row = rows[0] || null;
  } catch (err) {
    // Table might not exist yet if migrations weren't applied.
    return {
      object_number: objectNumber,
      available: false,
      status: 'missing',
      chunk_count: 0,
      reason: 'RAG index status table is not available yet.',
    };
  }

  const status = row?.status || 'pending';
  const chunkCount = Number(row?.chunk_count || 0);
  const available = status === 'ready' && chunkCount > 0;
  const reason =
    available
      ? null
      : status === 'disabled'
        ? 'Индекс знаний отключен настройками.'
        : status === 'failed'
          ? row?.error || 'Индекс знаний не собран.'
          : 'Ассистент доступен после завершения индекса знаний.';

  return {
    object_number: objectNumber,
    available,
    status,
    chunk_count: chunkCount,
    updated_at: row?.updated_at || null,
    error: row?.error || null,
    reason,
  };
}

