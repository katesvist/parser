async function requireJwtUser(auth) {
  if (!auth || auth.mode !== 'jwt') {
    throw new Error('JWT required.');
  }
  let user = null;
  if (auth.userId) {
    user = await findUserById(auth.userId);
  }
  if (!user && auth.email) {
    user = await findUserByEmail(auth.email);
  }
  if (!user) {
    throw new Error('User not found.');
  }
  return user;
}

