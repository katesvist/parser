function normalizeRestUrl(value) {
  const trimmed = value.replace(/\/+$/, '');
  if (trimmed.endsWith('/rest/v1')) {
    return trimmed;
  }
  return `${trimmed}/rest/v1`;
}

function isAuthorized(req) {
  if (API_KEYS.length === 0) {
    return false;
  }
  const headerKey = req.headers['x-api-key'];
  const authHeader = req.headers.authorization || '';
  const bearer = authHeader.startsWith('Bearer ') ? authHeader.slice(7) : '';
  const key = (headerKey || bearer || '').toString().trim();
  return API_KEYS.includes(key);
}

function getAuthContext(req) {
  const token = getBearerToken(req);
  if (token) {
    try {
      if (!AUTH_JWT_SECRET) {
        return { ok: false, error: 'JWT secret is not configured.' };
      }
      const payload = verifyJwt(token, AUTH_JWT_SECRET);
      const role = resolveRole(payload);
      return {
        ok: true,
        mode: 'jwt',
        role,
        policy: getPolicyForRole(role),
        userId: payload.sub,
        email: payload.email,
        payload,
      };
    } catch (error) {
      return {
        ok: false,
        error: error instanceof Error ? error.message : 'Invalid token.',
      };
    }
  }

  if (API_KEYS.length > 0 && isAuthorized(req)) {
    const role = 'admin';
    return { ok: true, mode: 'api_key', role, policy: getPolicyForRole(role) };
  }

  return { ok: false, error: 'Missing Authorization header.' };
}

function getBearerToken(req) {
  const authHeader = (req.headers.authorization || '').toString();
  if (!authHeader.startsWith('Bearer ')) return '';
  return authHeader.slice(7).trim();
}

function setCorsHeaders(req, res) {
  const origin = (req.headers.origin || '').toString();
  const allowAny = CORS_ORIGINS.includes('*');
  if (allowAny) {
    res.setHeader('Access-Control-Allow-Origin', '*');
  } else if (origin && CORS_ORIGINS.includes(origin)) {
    res.setHeader('Access-Control-Allow-Origin', origin);
    res.setHeader('Vary', 'Origin');
  }
  res.setHeader(
    'Access-Control-Allow-Headers',
    'Content-Type, Authorization, X-Api-Key'
  );
  res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PATCH, DELETE, OPTIONS');
}

function sendJson(res, status, payload) {
  const body = JSON.stringify(payload);
  res.writeHead(status, {
    'Content-Type': 'application/json; charset=utf-8',
    'Content-Length': Buffer.byteLength(body),
  });
  res.end(body);
}

async function handleTendersRequest(searchParams, auth) {
  const page = clampInt(parseInt(searchParams.get('page') || '1', 10) || 1, 1);
  const limit = clampInt(
    parseInt(searchParams.get('limit') || `${DEFAULT_LIMIT}`, 10) ||
      DEFAULT_LIMIT,
    1,
    MAX_LIMIT
  );
  const offset = (page - 1) * limit;

  const params = new URLSearchParams();
  params.set('select', '*');
  params.set('order', 'startdt.desc');
  params.set('limit', String(limit));
  params.set('offset', String(offset));
  params.set('archived_at', 'is.null');

  const region = normalizeFilterValue(searchParams.get('region'));
  const stage = normalizeFilterValue(searchParams.get('stage'));
  const procedureType = normalizeFilterValue(searchParams.get('procedure_type'));
  const fz = normalizeFilterValue(searchParams.get('fz'));
  const minPrice = normalizeNumber(searchParams.get('min_price'));
  const maxPrice = normalizeNumber(searchParams.get('max_price'));
  const search = normalizeFilterValue(searchParams.get('search'));
  const okpd2 = normalizeFilterValue(searchParams.get('okpd2'));
  const inn = normalizeFilterValue(searchParams.get('inn'));
  const objectNumber = normalizeFilterValue(searchParams.get('object_number'));
  const ikz = normalizeFilterValue(searchParams.get('ikz'));
  const startDateFrom = normalizeDate(searchParams.get('start_date_from'));
  const startDateTo = normalizeDate(searchParams.get('start_date_to'));
  const endDateFrom = normalizeDate(searchParams.get('end_date_from'));
  const endDateTo = normalizeDate(searchParams.get('end_date_to'));
  const disjunctionGroups = [];

  if (region) {
    const regionTokens = splitAliasFilterValue(region);
    if (regionTokens.length === 1) {
      params.set('deliveryplace', `ilike.*${regionTokens[0]}*`);
    } else if (regionTokens.length > 1) {
      disjunctionGroups.push(
        regionTokens.map((token) => `deliveryplace.ilike.*${token}*`).join(',')
      );
    }
  }
  if (stage) {
    params.set('etap_zakupki', `ilike.*${stage}*`);
  }
  if (procedureType) {
    params.set('placingway_name', `ilike.*${procedureType}*`);
  }
  if (fz) {
    params.set('zakon', `eq.${fz}`);
  }
  if (typeof minPrice === 'number') {
    params.set('maxprice', `gte.${minPrice}`);
  }
  if (typeof maxPrice === 'number') {
    params.set('maxprice', `lte.${maxPrice}`);
  }

  if (okpd2) {
    disjunctionGroups.push(
      [
        `okpd2info.ilike.*${okpd2}*`,
        `industry_okpd2.ilike.*${okpd2}*`,
      ].join(',')
    );
  }
  if (inn) {
    params.set('inn', `ilike.*${inn}*`);
  }
  if (objectNumber) {
    params.set('object_number', `ilike.*${objectNumber}*`);
  }
  if (startDateFrom) {
    params.set('startdt', `gte.${startDateFrom}`);
  }
  if (startDateTo) {
    params.set('startdt', `lte.${startDateTo}`);
  }
  if (endDateFrom) {
    params.set('enddt', `gte.${endDateFrom}`);
  }
  if (endDateTo) {
    params.set('enddt', `lte.${endDateTo}`);
  }

  const searchTokens = tokenizeSearchQuery(search);
  if (searchTokens.length > 0) {
    for (const token of searchTokens) {
      const like = `ilike.*${token}*`;
      const searchFields = [
        `object_number.${like}`,
        `object_info.${like}`,
        `kvr_info.${like}`,
        `shortname.${like}`,
        `fullname.${like}`,
        `inn.${like}`,
        `okpd2info.${like}`,
        `industry_okpd2.${like}`,
        `placingway_name.${like}`,
        `etp_name.${like}`,
        `deliveryplace.${like}`,
        `countryfullname.${like}`,
        `ikz_code.${like}`,
        `ikz_number.${like}`,
        `ikz_ordernumber.${like}`,
      ];
      if (SEARCH_MORPHOLOGY_ENABLED) {
        const morphFields = buildMorphologyFields(token);
        if (morphFields.length > 0) {
          searchFields.push(...morphFields);
        }
      }
      if (/^\d{6,}$/.test(token)) {
        searchFields.push(`object_number.eq.${token}`);
      }
      disjunctionGroups.push(searchFields.join(','));
    }
  }
  if (ikz) {
    const like = `ilike.*${ikz}*`;
    const ikzFields = [
      `ikz_code.${like}`,
      `ikz_number.${like}`,
      `ikz_ordernumber.${like}`,
    ];
    disjunctionGroups.push(ikzFields.join(','));
  }

  if (disjunctionGroups.length === 1) {
    params.set('or', `(${disjunctionGroups[0]})`);
  } else if (disjunctionGroups.length > 1) {
    params.set(
      'and',
      `(${disjunctionGroups.map((group) => `or(${group})`).join(',')})`
    );
  }

  const tendersResponse = await fetchSupabase('tenders_gov', params, {
    preferCount: true,
  });
  const tenders = Array.isArray(tendersResponse.data)
    ? tendersResponse.data
    : [];
  const total = parseTotal(tendersResponse.contentRange);

  const normalized = tenders.map((tender) =>
    applyAccessPolicy(tender, auth.policy)
  );

  return {
    page,
    limit,
    total,
    tenders: normalized,
  };
}

function omitRelations(tender) {
  const { tender_items, tender_attachments, ...rest } = tender;
  return rest;
}

async function handleTenderDetailRequest(tenderId, auth) {
  const params = new URLSearchParams();
  params.set('select', '*,tender_items(*),tender_attachments(*)');
  params.set('limit', '1');
  params.set('archived_at', 'is.null');

  if (/^\d+$/.test(tenderId)) {
    params.set('or', `(object_number.eq.${tenderId},id.eq.${tenderId})`);
  } else {
    params.set('object_number', `eq.${tenderId}`);
  }

  const response = await fetchSupabase('tenders_gov', params);
  const tender = Array.isArray(response.data) ? response.data[0] : null;
  if (!tender) {
    return null;
  }

  const analyticsMap = await loadAnalytics([tender.object_number]);
  const attachmentsSummaryMap = await loadAttachmentSummaries([tender]);
  const analytics = analyticsMap.get(tender.object_number);
  const items = Array.isArray(tender.tender_items) ? tender.tender_items : [];
  const attachments = Array.isArray(tender.tender_attachments)
    ? tender.tender_attachments.map((attachment) =>
        mergeAttachmentSummary(attachment, attachmentsSummaryMap)
      )
    : [];

  return {
    ...applyAccessPolicy(omitRelations(tender), auth.policy),
    items,
    attachments: applyAttachmentPolicy(attachments, auth.policy),
    analytics: auth.policy.canSeeAnalytics ? analytics || undefined : undefined,
  };
}

function applyAccessPolicy(tender, policy) {
  const next = { ...tender };

  if (!policy.canSeeContacts) {
    stripFields(next, [
      'person_lastname',
      'person_firstname',
      'person_middlename',
      'contactemail',
      'contactphone',
      'contactfax',
      'orgpostaddress',
      'orgfactaddress',
    ]);
  }

  if (!policy.canSeeFinance) {
    stripFields(next, [
      'bik',
      'settlementaccount',
      'personalaccount',
      'creditorgname',
      'corraccountnumber',
    ]);
  }

  if (!policy.canSeeAnalytics) {
    stripFields(next, [
      'risk_score',
      'risk_reasons',
      'estimated_complexity',
      'estimated_winner_type',
      'key_requirements',
      'key_terms',
      'positions_with_foreign_ban',
      'positions_with_subcontractor_req',
      'guarantee_percent',
      'delivery_days',
      'warranty_months',
      'is_subcontractors_req',
      'has_impossible_deadlines',
      'has_payment_guarantees_req',
      'has_strict_quality_requirements',
      'has_technical_audit_req',
      'recommendation_text',
      'summary',
      'items_analysis',
    ]);
  }

  return next;
}

function applyAttachmentPolicy(attachments, policy) {
  if (policy.canSeeAnalytics) return attachments;
  return attachments.map((attachment) => {
    const next = { ...attachment };
    stripFields(next, ['summary', 'key_requirements', 'key_terms', 'risk_flags']);
    return next;
  });
}

function stripFields(target, fields) {
  for (const field of fields) {
    if (field in target) {
      delete target[field];
    }
  }
}

function resolveRole(payload) {
  const role = payload?.role || 'viewer';

  if (role === 'service_role') return 'admin';
  if (role === 'admin') return 'admin';
  if (role === 'analyst') return 'analyst';
  return 'viewer';
}

function getPolicyForRole(role) {
  if (role === 'admin') {
    return { canSeeContacts: true, canSeeFinance: true, canSeeAnalytics: true };
  }
  if (role === 'analyst') {
    return { canSeeContacts: false, canSeeFinance: false, canSeeAnalytics: true };
  }
  return { canSeeContacts: false, canSeeFinance: false, canSeeAnalytics: false };
}

async function loadAnalytics(objectNumbers) {
  if (!objectNumbers.length) {
    return new Map();
  }

  const params = new URLSearchParams();
  params.set('select', '*');
  params.set('object_number', `in.(${objectNumbers.join(',')})`);

  const response = await fetchSupabase('tender_analytics', params);
  const map = new Map();
  for (const row of response.data || []) {
    if (row?.object_number) {
      map.set(row.object_number, row);
    }
  }
  return map;
}

async function loadAttachmentSummaries(tenders) {
  const attachments = [];
  for (const tender of tenders) {
    if (Array.isArray(tender.tender_attachments)) {
      attachments.push(...tender.tender_attachments);
    }
  }

  const ids = attachments.map((attachment) => attachment.id).filter(Boolean);
  if (!ids.length) {
    return new Map();
  }

  const params = new URLSearchParams();
  params.set('select', '*');
  params.set('attachment_id', `in.(${ids.join(',')})`);

  const response = await fetchSupabase('tender_attachments_summary', params);
  const map = new Map();
  for (const row of response.data || []) {
    if (row?.attachment_id) {
      map.set(String(row.attachment_id), row);
    }
  }
  return map;
}

function mergeAttachmentSummary(attachment, summaryMap) {
  const summary = summaryMap.get(String(attachment.id));
  if (!summary) {
    return attachment;
  }
  return {
    ...attachment,
    summary: summary.summary ?? null,
    key_requirements: summary.key_requirements ?? null,
    key_terms: summary.key_terms ?? null,
    risk_flags: summary.risk_flags ?? summary.risks ?? null,
  };
}

async function fetchSupabase(path, params, options = {}) {
  const url = new URL(path.replace(/^\//, ''), `${restBaseUrl}/`);
  for (const [key, value] of params.entries()) {
    url.searchParams.set(key, value);
  }

  const headers = {
    apikey: SERVICE_ROLE_KEY,
    Authorization: `Bearer ${SERVICE_ROLE_KEY}`,
    Accept: 'application/json',
  };
  if (options.preferCount) {
    headers.Prefer = 'count=exact';
  }

  const response = await fetch(url, { headers });
  const text = await response.text();
  const data = text ? JSON.parse(text) : null;

  if (!response.ok) {
    const message =
      (data && data.message) ||
      (data && data.error) ||
      response.statusText ||
      'Supabase request failed.';
    throw new Error(message);
  }

  return {
    data,
    contentRange: response.headers.get('content-range'),
  };
}

async function mutateSupabase(path, options = {}) {
  const {
    method = 'POST',
    params,
    body,
    prefer,
  } = options;
  const url = new URL(path.replace(/^\//, ''), `${restBaseUrl}/`);
  if (params) {
    for (const [key, value] of params.entries()) {
      url.searchParams.set(key, value);
    }
  }

  const headers = {
    apikey: SERVICE_ROLE_KEY,
    Authorization: `Bearer ${SERVICE_ROLE_KEY}`,
    'Content-Type': 'application/json',
    Accept: 'application/json',
  };
  if (prefer) {
    headers.Prefer = prefer;
  }

  const response = await fetch(url, {
    method,
    headers,
    body: body ? JSON.stringify(body) : undefined,
  });
  const text = await response.text();
  const data = text ? JSON.parse(text) : null;
  if (!response.ok) {
    const message =
      (data && data.message) ||
      (data && data.error) ||
      response.statusText ||
      'Supabase request failed.';
    throw new Error(message);
  }
  return data;
}

async function callSupabaseRpc(functionName, payload) {
  const cleaned = String(functionName || '').replace(/^\/+/, '');
  return mutateSupabase(`rpc/${cleaned}`, { method: 'POST', body: payload });
}

function parseContentRangeCount(contentRange) {
  if (!contentRange) return null;
  const match = contentRange.match(/\/(\d+)$/);
  if (!match) return null;
  const value = Number(match[1]);
  return Number.isFinite(value) ? value : null;
}

async function countSupabase(table, params) {
  const query = new URLSearchParams();
  query.set('select', 'id');
  query.set('limit', '1');
  if (params) {
    for (const [key, value] of params.entries()) {
      query.set(key, value);
    }
  }
  const response = await fetchSupabase(table, query, { preferCount: true });
  const count = parseContentRangeCount(response.contentRange);
  if (typeof count === 'number') return count;
  return Array.isArray(response.data) ? response.data.length : 0;
}

