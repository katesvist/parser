    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const inputJson = item.json;\n  let raw = inputJson.output || inputJson.text || \"\";\n\n  if (typeof raw !== \"string\") {\n    raw = JSON.stringify(raw);\n  }\n\n  let clean = raw.trim();\n\n  // убираем ```\n  if (clean.startsWith(\"```json\")) {\n    clean = clean.slice(7).trim();\n  }\n\n  // убираем ```\n  if (clean.startsWith(\"```\")) {\n    clean = clean.slice(3).trim();\n  }\n\n  // убираем ```\n  if (clean.endsWith(\"```\")) {\n    clean = clean.slice(0, clean.length - 3).trim();\n  }\n\n  let parsedData;\n  try {\n    parsedData = JSON.parse(clean);\n  } catch (e) {\n    parsedData = {\n      error: \"JSON parse failed\",\n      rawContent: raw,\n    };\n  }\n\n  const object_number =\n    (parsedData && parsedData.object_number) ||\n    inputJson.object_number ||\n    null;\n\n  return {\n    json: {\n      ...inputJson,\n      ...parsedData,\n      object_number,\n    },\n  };\n});\n"
      },
